<script>
// EmailJS init
(function(){emailjs.init({publicKey:"YOUR_PUBLIC_KEY"});})();

// Loader
let n=0;const lp=document.getElementById('ldpct');
const li=setInterval(()=>{n+=Math.floor(Math.random()*7)+3;if(n>=100){n=100;clearInterval(li);}lp.textContent=n+'%';},55);
window.addEventListener('load',()=>setTimeout(()=>document.getElementById('loader').classList.add('gone'),1900));

// Cursor
const dot=document.getElementById('curDot'),ring=document.getElementById('curRing');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;dot.style.left=mx+'px';dot.style.top=my+'px';});
(function loop(){rx+=(mx-rx)*.12;ry+=(my-ry)*.12;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(loop);})();

// Nav
window.addEventListener('scroll',()=>document.getElementById('nav').classList.toggle('solid',window.scrollY>30));

// Menu
let mo=false;
function toggleM(){mo=!mo;document.getElementById('moverlay').classList.toggle('open',mo);document.getElementById('hbg').classList.toggle('open',mo);document.body.style.overflow=mo?'hidden':'';}
function closeM(){mo=false;document.getElementById('moverlay').classList.remove('open');document.getElementById('hbg').classList.remove('open');document.body.style.overflow='';}

// Canvas particles
const cv=document.getElementById('hcanvas'),cx=cv.getContext('2d');
function rsz(){cv.width=cv.offsetWidth;cv.height=cv.offsetHeight;}rsz();
window.addEventListener('resize',rsz);
let hm={x:0,y:0};
document.addEventListener('mousemove',e=>{const r=cv.getBoundingClientRect();hm.x=e.clientX-r.left;hm.y=e.clientY-r.top;});
class P{constructor(){this.init();}init(){this.x=Math.random()*(cv.width||1200);this.y=Math.random()*(cv.height||800);this.vx=(Math.random()-.5)*.35;this.vy=(Math.random()-.5)*.35;this.r=Math.random()*1.2+.3;this.life=0;this.maxL=Math.random()*400+200;this.a=0;}tick(){this.life++;this.a=this.life<80?this.life/80:this.life>this.maxL-80?(this.maxL-this.life)/80:1;this.a*=.55;this.x+=this.vx;this.y+=this.vy;const dx=hm.x-this.x,dy=hm.y-this.y,d=Math.sqrt(dx*dx+dy*dy);if(d<140){this.x-=dx*.013;this.y-=dy*.013;}if(this.life>this.maxL)this.init();}draw(){cx.beginPath();cx.arc(this.x,this.y,this.r,0,Math.PI*2);cx.fillStyle=`rgba(200,168,75,${this.a})`;cx.fill();}}
const pts=[];for(let i=0;i<110;i++)pts.push(new P());
function drawLines(){pts.forEach((p,i)=>{for(let j=i+1;j<pts.length;j++){const p2=pts[j],dx=p.x-p2.x,dy=p.y-p2.y,d=Math.sqrt(dx*dx+dy*dy);if(d<110){cx.beginPath();cx.moveTo(p.x,p.y);cx.lineTo(p2.x,p2.y);cx.strokeStyle=`rgba(200,168,75,${.1*(1-d/110)*Math.min(p.a,p2.a)*2})`;cx.lineWidth=.4;cx.stroke();}}});}
function anim(){cx.clearRect(0,0,cv.width,cv.height);drawLines();pts.forEach(p=>{p.tick();p.draw();});requestAnimationFrame(anim);}
anim();

// Reveal
const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('v');obs.unobserve(e.target);}}),{threshold:.1});
document.querySelectorAll('.r').forEach(el=>obs.observe(el));

// FAQ
function tfaq(btn){const fi=btn.closest('.fi'),op=fi.classList.contains('open');document.querySelectorAll('.fi.open').forEach(e=>e.classList.remove('open'));if(!op)fi.classList.add('open');}

// Scroll vers contact avec formule pré-remplie
function openContact(formule){
  document.getElementById('ctamsg').value='Bonjour Riccardo, je suis intéressé par la formule ' + formule + '. Pouvez-vous me contacter pour un devis ?';
  document.getElementById('contact').scrollIntoView({behavior:'smooth'});
  setTimeout(()=>document.getElementById('ctaemail').focus(),600);
}

// Envoi email via EmailJS
async function sendEmail(){
  const email=document.getElementById('ctaemail').value;
  const msg=document.getElementById('ctamsg').value;
  if(!email||!email.includes('@')){
    document.getElementById('ctaemail').placeholder='Email invalide.';
    return;
  }
  const btn=document.getElementById('submit-txt');
  btn.textContent='Envoi...';
  try {
    await emailjs.send('service_riccardo','template_riccardo',{
      from_email: email,
      message: msg||'(pas de message)',
      to_email: 'riccardocerbo.ecmmrc@gmail.com'
    });
    document.getElementById('ctaSuccess').style.display='block';
    document.getElementById('ctaemail').value='';
    document.getElementById('ctamsg').value='';
    btn.textContent='Envoyé ✓';
  } catch(e) {
    // Fallback : ouvre le client mail natif
    const subject=encodeURIComponent('Demande de devis — Riccardo B2B');
    const body=encodeURIComponent('Email: '+email+'\n\n'+msg);
    window.location.href='mailto:riccardocerbo.ecmmrc@gmail.com?subject='+subject+'&body='+body;
    btn.textContent='Envoyer →';
  }
}
</script>
