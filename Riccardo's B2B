.cta-form-wrap{max-width:500px;margin:0 auto}
.cta-form-label{font-family:var(--mono);font-size:.6rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);margin-bottom:10px;display:block;text-align:left}
.cta-form{display:flex;background:var(--bg3);border:1px solid var(--gold-border);margin-bottom:10px}
.cta-input{flex:1;background:none;border:none;outline:none;padding:16px 20px;font-family:var(--sans);font-size:.88rem;color:var(--white);font-weight:300}
.cta-input::placeholder{color:var(--gray)}
.cta-submit{background:var(--gold);color:var(--bg);border:none;cursor:none;padding:16px 26px;font-family:var(--mono);font-size:.58rem;letter-spacing:.13em;text-transform:uppercase;white-space:nowrap;position:relative;overflow:hidden;transition:background .3s}
.cta-submit::before{content:'';position:absolute;inset:0;background:var(--gold3);transform:scaleX(0);transform-origin:left;transition:transform .4s}
.cta-submit:hover::before{transform:scaleX(1)}
.cta-submit span{position:relative;z-index:1}
.cta-msg-row{display:flex;gap:0;background:var(--bg3);border:1px solid var(--gold-border);border-top:none;margin-bottom:12px}
.cta-textarea{flex:1;background:none;border:none;outline:none;padding:14px 20px;font-family:var(--sans);font-size:.86rem;color:var(--white);font-weight:300;resize:none;min-height:80px}
.cta-textarea::placeholder{color:var(--gray)}
.cta-note{font-family:var(--mono);font-size:.55rem;color:var(--gray2);letter-spacing:.1em;text-transform:uppercase}
.cta-success{font-family:var(--serif);font-style:italic;font-size:1rem;color:var(--gold);margin-top:16px;display:none}

footer{border-top:1px solid var(--gold-border);padding:70px 64px 36px;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:56px}
