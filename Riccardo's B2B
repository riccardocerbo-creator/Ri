<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Riccardo's B2B — Sites Web · Paris</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,600&family=DM+Mono:wght@300;400;500&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
<style>
:root {
  --bg:#04030a; --bg2:#07060f; --bg3:#0d0c1a;
  --gold:#c8a84b; --gold2:#e8c97a; --gold3:#f5e0a0;
  --gold-dim:rgba(200,168,75,0.07); --gold-border:rgba(200,168,75,0.18);
  --white:#f0ece4; --gray:#9994b0; --gray2:#2a2838;
  --mono:'DM Mono',monospace; --serif:'Cormorant Garamond',Georgia,serif; --sans:'Outfit',sans-serif;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:var(--sans);background:var(--bg);color:var(--white);overflow-x:hidden;cursor:none}

.cur-dot{position:fixed;width:6px;height:6px;background:var(--gold);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%)}
.cur-ring{position:fixed;width:32px;height:32px;border:1px solid rgba(200,168,75,.4);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%)}

#loader{position:fixed;inset:0;background:var(--bg);z-index:9000;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:16px;transition:opacity 1s,visibility 1s}
#loader.gone{opacity:0;visibility:hidden;pointer-events:none}
.ld-word{font-family:var(--serif);font-size:clamp(2rem,5vw,4rem);font-weight:300;letter-spacing:.15em;color:var(--white)}
.ld-word em{color:var(--gold);font-style:italic}
.ld-bar{width:200px;height:1px;background:var(--gray2);overflow:hidden}
.ld-fill{height:100%;background:linear-gradient(90deg,var(--gold),var(--gold3));width:0;animation:ldfill 1.5s ease .4s forwards}
@keyframes ldfill{to{width:100%}}
.ld-pct{font-family:var(--mono);font-size:.7rem;color:var(--gold);letter-spacing:.1em}

nav{position:fixed;top:0;left:0;right:0;z-index:800;padding:0 64px;height:76px;display:flex;align-items:center;justify-content:space-between;transition:all .5s}
nav.solid{background:rgba(4,3,10,.92);backdrop-filter:blur(24px);border-bottom:1px solid var(--gold-border)}
.n-logo{font-family:var(--serif);font-weight:300;font-size:1.2rem;letter-spacing:.1em;text-decoration:none;color:var(--white);display:flex;align-items:baseline;gap:3px}
.n-logo-r{color:var(--gold);font-style:italic;font-size:1.5rem;line-height:1}
.n-center{display:flex;gap:40px;list-style:none;position:absolute;left:50%;transform:translateX(-50%)}
.n-center a{font-family:var(--mono);font-size:.62rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gray);text-decoration:none;position:relative;transition:color .3s}
.n-center a::after{content:'';position:absolute;bottom:-2px;left:0;width:0;height:1px;background:var(--gold);transition:width .3s}
.n-center a:hover{color:var(--gold)}
.n-center a:hover::after{width:100%}
.n-cta{font-family:var(--mono);font-size:.6rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);text-decoration:none;border:1px solid var(--gold-border);padding:10px 20px;position:relative;overflow:hidden;transition:color .3s}
.n-cta::before{content:'';position:absolute;inset:0;background:var(--gold);transform:scaleX(0);transform-origin:left;transition:transform .4s cubic-bezier(.4,0,.2,1)}
.n-cta:hover{color:var(--bg)}
.n-cta:hover::before{transform:scaleX(1)}
.n-cta span{position:relative;z-index:1}
.hbg{background:none;border:none;cursor:none;padding:6px;display:flex;flex-direction:column;gap:5px}
.hbg span{display:block;width:24px;height:1px;background:var(--white);transition:all .4s;transform-origin:center}
.hbg.open span:nth-child(1){transform:translateY(6px) rotate(45deg)}
.hbg.open span:nth-child(2){opacity:0;transform:scaleX(0)}
.hbg.open span:nth-child(3){transform:translateY(-6px) rotate(-45deg)}

.moverlay{position:fixed;inset:0;background:var(--bg);z-index:700;display:flex;align-items:center;justify-content:center;opacity:0;visibility:hidden;transition:opacity .5s,visibility .5s}
.moverlay.open{opacity:1;visibility:visible}
.mov-links{display:flex;flex-direction:column;gap:8px;text-align:center}
.mov-links a{font-family:var(--serif);font-style:italic;font-size:clamp(2.5rem,5vw,4.5rem);font-weight:300;color:var(--white);text-decoration:none;transition:color .3s}
.mov-links a:hover{color:var(--gold)}
.mov-sub{margin-top:40px;text-align:center;font-family:var(--mono);font-size:.6rem;color:var(--gray);letter-spacing:.15em;text-transform:uppercase}

.hero{min-height:100vh;position:relative;display:flex;align-items:center;overflow:hidden}
#hcanvas{position:absolute;inset:0;width:100%;height:100%;z-index:0;opacity:.5}
.hero-grid{position:absolute;inset:0;z-index:1;background-image:linear-gradient(rgba(200,168,75,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(200,168,75,.025) 1px,transparent 1px);background-size:80px 80px;mask-image:radial-gradient(ellipse at 40% 50%,black 20%,transparent 70%)}
.hero-vignette{position:absolute;inset:0;z-index:2;background:radial-gradient(ellipse at 25% 50%,transparent 25%,rgba(4,3,10,.75) 65%)}
.hero-content{position:relative;z-index:3;padding:0 64px;width:100%;display:grid;grid-template-columns:1fr 420px;gap:60px;align-items:center;padding-top:76px}
.hc-left{display:flex;flex-direction:column;align-items:flex-start}
.h-tag{display:flex;align-items:center;gap:10px;font-family:var(--mono);font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold2);margin-bottom:28px;opacity:0;animation:hup .8s ease .4s forwards}
.h-tag-dot{width:4px;height:4px;background:var(--gold2);border-radius:50%;animation:blink 2s infinite;flex-shrink:0}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
.h-tag-line{width:32px;height:1px;background:var(--gold);opacity:.5;flex-shrink:0}
.h-h1{font-family:var(--serif);font-size:clamp(3rem,5.5vw,6.5rem);font-weight:300;line-height:.97;letter-spacing:-.01em;margin-bottom:28px;opacity:0;animation:hup .9s ease .6s forwards}
.h-h1 .it{font-style:italic;color:var(--gold)}
.h-h1 .out{-webkit-text-stroke:1px rgba(200,168,75,.45);color:transparent;font-style:italic}
.h-desc{font-size:.95rem;font-weight:300;color:var(--gray);line-height:1.85;max-width:460px;margin-bottom:44px;opacity:0;animation:hup .9s ease .8s forwards}
.h-desc strong{color:var(--white);font-weight:500}
.h-actions{display:flex;align-items:center;gap:24px;opacity:0;animation:hup .9s ease 1s forwards}
.btn-gold{display:inline-flex;align-items:center;gap:10px;background:var(--gold);color:var(--bg);font-family:var(--mono);font-size:.62rem;letter-spacing:.15em;text-transform:uppercase;padding:16px 34px;text-decoration:none;position:relative;overflow:hidden;transition:transform .3s}
.btn-gold::before{content:'';position:absolute;inset:0;background:var(--gold3);transform:scaleX(0);transform-origin:left;transition:transform .4s cubic-bezier(.4,0,.2,1)}
.btn-gold:hover{transform:translateY(-3px)}
.btn-gold:hover::before{transform:scaleX(1)}
.btn-gold span{position:relative;z-index:1}
.btn-txt{font-family:var(--mono);font-size:.6rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gray);text-decoration:none;display:flex;align-items:center;gap:6px;transition:color .3s}
.btn-txt:hover{color:var(--gold)}
.btn-txt .a{transition:transform .3s}
.btn-txt:hover .a{transform:translateX(4px)}
.hc-right{opacity:0;animation:hup .9s ease 1.1s forwards}
.h-cards{display:flex;flex-direction:column;gap:3px}
.h-card{background:rgba(13,12,26,.88);border:1px solid var(--gold-border);padding:20px 24px;backdrop-filter:blur(16px);position:relative;overflow:hidden}
.h-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2px;background:linear-gradient(180deg,var(--gold),transparent)}
.hc-lbl{font-family:var(--mono);font-size:.56rem;color:var(--gray);letter-spacing:.14em;text-transform:uppercase;margin-bottom:5px}
.hc-val{font-family:var(--serif);font-size:1.4rem;font-weight:600;color:var(--gold);line-height:1}
.hc-sub{font-size:.7rem;color:var(--gray);margin-top:2px;font-weight:300}
@keyframes hup{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}

.marquee-wrap{border-top:1px solid var(--gold-border);border-bottom:1px solid var(--gold-border);padding:15px 0;overflow:hidden;white-space:nowrap;position:relative}
.marquee-wrap::before,.marquee-wrap::after{content:'';position:absolute;top:0;bottom:0;width:100px;z-index:2}
.marquee-wrap::before{left:0;background:linear-gradient(90deg,var(--bg),transparent)}
.marquee-wrap::after{right:0;background:linear-gradient(-90deg,var(--bg),transparent)}
.marquee-inner{display:inline-flex;animation:marq 26s linear infinite}
.m-item{font-family:var(--serif);font-style:italic;font-size:1rem;font-weight:300;color:var(--gray);padding:0 44px;display:flex;align-items:center;gap:44px}
.m-item::after{content:'◆';font-style:normal;font-size:.4rem;color:var(--gold)}
@keyframes marq{from{transform:translateX(0)}to{transform:translateX(-50%)}}

.about{padding:130px 64px;display:grid;grid-template-columns:1fr 1fr;gap:90px;align-items:center}
.s-tag{font-family:var(--mono);font-size:.58rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:14px;display:flex;align-items:center;gap:14px}
.s-tag::after{content:'';flex:1;height:1px;background:var(--gold-border)}
.s-h2{font-family:var(--serif);font-size:clamp(2rem,3.5vw,3.5rem);font-weight:300;line-height:1.1;letter-spacing:-.01em;margin-bottom:24px}
.s-h2 em{font-style:italic;color:var(--gold);display:block}
.s-p{font-size:.9rem;font-weight:300;color:var(--gray);line-height:1.9;margin-bottom:14px}
.s-p strong{color:var(--white);font-weight:500}
.honest-card{margin-top:32px;padding:26px;background:var(--gold-dim);border:1px solid var(--gold-border);position:relative}
.honest-card::before{content:'"';font-family:var(--serif);font-size:5rem;font-weight:300;position:absolute;top:-12px;left:16px;color:var(--gold);opacity:.15;line-height:1}
.hc-text{font-family:var(--serif);font-style:italic;font-size:1rem;font-weight:300;color:var(--white);line-height:1.7}
.hc-sig{margin-top:12px;font-family:var(--mono);font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;color:var(--gold)}
.a-feats{display:flex;flex-direction:column;gap:3px}
.a-feat{padding:22px 28px;background:var(--bg3);border:1px solid var(--gold-border);display:flex;gap:18px;align-items:flex-start;transition:border-color .3s,background .3s;position:relative;overflow:hidden}
.a-feat::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2px;background:var(--gold);transform:scaleY(0);transform-origin:top;transition:transform .4s}
.a-feat:hover{border-color:var(--gold);background:rgba(200,168,75,.04)}
.a-feat:hover::before{transform:scaleY(1)}
.af-n{font-family:var(--serif);font-size:2rem;font-weight:300;color:var(--gold);opacity:.3;flex-shrink:0;line-height:1}
.af-title{font-size:.88rem;font-weight:600;margin-bottom:4px}
.af-desc{font-size:.8rem;color:var(--gray);font-weight:300;line-height:1.6}

/* PROCESS */
.process{padding:130px 64px}
.proc-header{text-align:center;margin-bottom:80px}
.sh2{font-family:var(--serif);font-size:clamp(2rem,3.5vw,3.8rem);font-weight:300;letter-spacing:-.01em}
.sh2 em{font-style:italic;color:var(--gold)}
.proc-steps{display:grid;grid-template-columns:repeat(4,1fr);position:relative}
.proc-steps::before{content:'';position:absolute;top:35px;left:calc(12.5% + 18px);right:calc(12.5% + 18px);height:1px;background:linear-gradient(90deg,transparent,var(--gold-border),var(--gold),var(--gold-border),transparent);animation:glow 3s ease-in-out infinite}
@keyframes glow{0%,100%{opacity:.4}50%{opacity:1}}
.ps{padding:0 24px;text-align:center;position:relative;z-index:1}
.ps-circle{width:70px;height:70px;margin:0 auto 24px;border:1px solid var(--gold-border);border-radius:50%;display:flex;align-items:center;justify-content:center;background:var(--bg);transition:border-color .4s,background .4s}
.ps:hover .ps-circle{border-color:var(--gold);background:var(--gold-dim)}
.ps-n{font-family:var(--serif);font-size:1.2rem;font-weight:300;color:var(--gold)}
.ps-title{font-size:.9rem;font-weight:600;margin-bottom:8px}
.ps-desc{font-size:.8rem;color:var(--gray);font-weight:300;line-height:1.7}

/* PRICING */
.pricing{padding:130px 64px;background:var(--bg2)}
.price-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:3px;margin-top:70px}
.pc{padding:40px 28px;background:var(--bg3);border:1px solid var(--gold-border);position:relative;overflow:hidden;transition:transform .4s cubic-bezier(.4,0,.2,1),border-color .4s;display:flex;flex-direction:column}
.pc:hover{transform:translateY(-7px);border-color:var(--gold)}
.pc.star{background:linear-gradient(145deg,#0d0c1a,#14111f);border-color:var(--gold)}
.pc.star::before{content:'Populaire';position:absolute;top:0;left:50%;transform:translateX(-50%);background:var(--gold);color:var(--bg);font-family:var(--mono);font-size:.52rem;letter-spacing:.13em;text-transform:uppercase;padding:5px 18px}
.pc::after{content:'';position:absolute;bottom:0;right:0;width:50px;height:50px;background:linear-gradient(135deg,transparent 50%,var(--gold-dim) 50%)}
.pc-tier{font-family:var(--mono);font-size:.56rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gray);margin-bottom:12px}
.pc-name{font-family:var(--serif);font-size:1.5rem;font-weight:300;margin-bottom:20px}
.pc-name em{color:var(--gold);font-style:italic}
.pc-div{height:1px;background:linear-gradient(90deg,var(--gold),transparent);margin-bottom:20px}
.pc-badge{display:inline-flex;align-items:center;gap:5px;background:var(--gold);color:var(--bg);font-family:var(--mono);font-size:.5rem;letter-spacing:.1em;text-transform:uppercase;padding:3px 10px;margin-bottom:7px}
.pc-badge::before{content:'◆';font-size:.4rem}
.pc-orig{font-family:var(--serif);font-size:1.4rem;font-weight:300;color:var(--gray);text-decoration:line-through;opacity:.45;line-height:1;margin-bottom:3px}
.pc-orig sup{font-size:.8rem}
.pc-price{font-family:var(--serif);font-size:2.8rem;font-weight:300;line-height:1;margin-bottom:3px}
.pc-price sup{font-size:1.2rem;color:var(--gold);vertical-align:top;margin-top:6px}
.pc-spots{font-family:var(--mono);font-size:.54rem;letter-spacing:.1em;text-transform:uppercase;color:var(--gold);margin-bottom:6px;display:flex;align-items:center;gap:5px}
.pc-spots::before{content:'';width:4px;height:4px;background:var(--gold);border-radius:50%;animation:blink 2s infinite}
.pc-note{font-family:var(--mono);font-size:.54rem;letter-spacing:.08em;text-transform:uppercase;color:var(--gray);margin-bottom:24px}
.pc-feats{list-style:none;display:flex;flex-direction:column;gap:10px;margin-bottom:20px;flex:1}
.pc-feats li{font-size:.8rem;color:var(--gray);font-weight:300;display:flex;align-items:flex-start;gap:8px;line-height:1.5}
.pc-feats li.on{color:var(--white)}
.pc-feats li .ck{color:var(--gold);flex-shrink:0;font-size:.65rem;margin-top:2px}

/* Demo link — harmonisé or, pas bleu */
.pc-demo{display:block;text-align:center;text-decoration:none;font-family:var(--mono);font-size:.54rem;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);border:1px solid var(--gold-border);padding:10px;margin-bottom:10px;position:relative;overflow:hidden;transition:color .3s,background .3s}
.pc-demo::before{content:'';position:absolute;inset:0;background:var(--gold-dim);transform:scaleX(0);transform-origin:left;transition:transform .4s}
.pc-demo:hover{color:var(--gold2)}
.pc-demo:hover::before{transform:scaleX(1)}
.pc-demo span{position:relative;z-index:1}

/* CTA button */
.btn-pc{display:block;text-align:center;font-family:var(--mono);font-size:.58rem;letter-spacing:.14em;text-transform:uppercase;padding:14px;position:relative;overflow:hidden;transition:color .3s;margin-top:4px;border:none;cursor:none;width:100%}
.btn-out{border:1px solid var(--gold-border);color:var(--gold);background:none}
.btn-out::before{content:'';position:absolute;inset:0;background:var(--gold-dim);transform:scaleX(0);transform-origin:left;transition:transform .4s}
.btn-out:hover::before{transform:scaleX(1)}
.btn-fill{background:var(--gold);color:var(--bg)}
.btn-fill::before{content:'';position:absolute;inset:0;background:var(--gold3);transform:scaleX(0);transform-origin:left;transition:transform .4s}
.btn-fill:hover{color:var(--bg)}
.btn-fill:hover::before{transform:scaleX(1)}
.btn-pc span{position:relative;z-index:1}

/* Email hint sous le bouton */
.pc-email-hint{font-family:var(--mono);font-size:.52rem;letter-spacing:.08em;text-transform:uppercase;color:var(--gold);opacity:.6;text-align:center;margin-top:8px}

/* SERVICES ADDITIONNELS */
.addons{padding:80px 64px;background:var(--bg)}
.addons-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:3px;margin-top:48px}
.addon{padding:28px 32px;background:var(--bg3);border:1px solid var(--gold-border);position:relative;overflow:hidden;transition:border-color .3s}
.addon:hover{border-color:var(--gold)}
.addon::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,var(--gold),transparent)}
.addon-ico{font-size:1.6rem;margin-bottom:14px;display:block}
.addon-title{font-family:var(--serif);font-size:1.1rem;font-weight:300;margin-bottom:6px}
.addon-title em{color:var(--gold);font-style:italic}
.addon-desc{font-size:.82rem;color:var(--gray);font-weight:300;line-height:1.7;margin-bottom:12px}
.addon-price{font-family:var(--mono);font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;color:var(--gold)}

/* REFONTE */
.refonte{padding:60px 64px;background:var(--bg2)}
.refonte-inner{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;padding:40px;border:1px solid var(--gold-border);background:var(--bg3);position:relative;overflow:hidden}
.refonte-inner::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--gold),var(--gold3),transparent)}
.ref-tag{font-family:var(--mono);font-size:.58rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);margin-bottom:12px}
.ref-h{font-family:var(--serif);font-size:clamp(1.5rem,2.5vw,2.2rem);font-weight:300;line-height:1.2;margin-bottom:16px}
.ref-h em{color:var(--gold);font-style:italic}
.ref-p{font-size:.88rem;color:var(--gray);font-weight:300;line-height:1.8}
.ref-p strong{color:var(--white);font-weight:500}
.ref-offer{display:flex;align-items:center;gap:16px;padding:20px 24px;background:var(--gold-dim);border:1px solid var(--gold-border)}
.ref-pct{font-family:var(--serif);font-size:3rem;font-weight:300;color:var(--gold);line-height:1}
.ref-detail{font-size:.85rem;color:var(--gray);font-weight:300;line-height:1.6}
.ref-detail strong{color:var(--white);font-weight:500;display:block;margin-bottom:3px}

/* TESTIMONIALS */
.testi{padding:130px 64px}
.testi-intro{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:end;margin-bottom:60px}
.testi-h2{font-family:var(--serif);font-size:clamp(2rem,3.5vw,3.5rem);font-weight:300;letter-spacing:-.01em}
.testi-h2 em{font-style:italic;color:var(--gold)}
.testi-honest{font-size:.86rem;color:var(--gray);font-weight:300;line-height:1.85}
.testi-honest strong{color:var(--white);font-weight:500}
.testi-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:3px}
.tc{padding:40px;background:var(--bg3);border:1px solid var(--gold-border);position:relative;overflow:hidden;transition:border-color .4s}
.tc:hover{border-color:var(--gold)}
.tc-q{font-family:var(--serif);font-size:5rem;font-weight:300;position:absolute;top:-5px;right:20px;color:var(--gold);opacity:.06;line-height:1}
.tc-stars{color:var(--gold);letter-spacing:3px;font-size:.7rem;margin-bottom:14px}
.tc-text{font-family:var(--serif);font-style:italic;font-size:1rem;font-weight:300;color:var(--gray);line-height:1.8;margin-bottom:22px}
.tc-auth{display:flex;align-items:center;gap:14px}
.tc-av{width:40px;height:40px;background:var(--gold-dim);border:1px solid var(--gold-border);display:flex;align-items:center;justify-content:center;font-family:var(--serif);font-style:italic;font-size:.95rem;color:var(--gold)}
.tc-name{font-weight:600;font-size:.85rem;margin-bottom:2px}
.tc-role{font-family:var(--mono);font-size:.56rem;color:var(--gray);letter-spacing:.08em;text-transform:uppercase}
