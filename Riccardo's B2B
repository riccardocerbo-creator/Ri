/* FAQ */
.faq{padding:130px 64px;background:var(--bg2)}
.faq-inner{display:grid;grid-template-columns:1fr 2fr;gap:90px}
.faq-h2{font-family:var(--serif);font-size:clamp(2rem,3vw,3rem);font-weight:300;line-height:1.1;letter-spacing:-.01em}
.faq-h2 em{font-style:italic;color:var(--gold);display:block}
.faq-note{margin-top:20px;font-size:.82rem;color:var(--gray);font-weight:300;line-height:1.7}
.faq-list{display:flex;flex-direction:column}
.fi{border-bottom:1px solid var(--gold-border)}
.fi:first-child{border-top:1px solid var(--gold-border)}
.fq{width:100%;padding:20px 0;display:flex;align-items:center;justify-content:space-between;background:none;border:none;cursor:none;font-family:var(--sans);font-size:.88rem;font-weight:500;color:var(--white);text-align:left;gap:16px;transition:color .3s}
.fq:hover{color:var(--gold)}
.fi-ico{width:18px;height:18px;flex-shrink:0;position:relative}
.fi-ico::before,.fi-ico::after{content:'';position:absolute;background:var(--gold);top:50%;left:50%;transform:translate(-50%,-50%);transition:transform .4s,opacity .4s}
.fi-ico::before{width:10px;height:1px}
.fi-ico::after{width:1px;height:10px}
.fi.open .fi-ico::after{transform:translate(-50%,-50%) rotate(90deg);opacity:0}
.fa{max-height:0;overflow:hidden;font-size:.83rem;color:var(--gray);font-weight:300;line-height:1.8;transition:max-height .5s cubic-bezier(.4,0,.2,1),padding .5s}
.fi.open .fa{max-height:200px;padding-bottom:20px}

/* CTA CONTACT — formulaire email réel */
.cta{padding:150px 64px;position:relative;overflow:hidden;text-align:center}
.cta::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:600px;height:600px;background:radial-gradient(circle,rgba(200,168,75,.07) 0%,transparent 65%);animation:cpulse 4s ease-in-out infinite}
@keyframes cpulse{0%,100%{transform:translate(-50%,-50%) scale(1)}50%{transform:translate(-50%,-50%) scale(1.12)}}
.cta-in{position:relative;z-index:1}
.cta-tag{font-family:var(--mono);font-size:.58rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:20px;display:flex;align-items:center;justify-content:center;gap:14px}
.cta-tag::before,.cta-tag::after{content:'';width:50px;height:1px;background:var(--gold-border)}
.cta-h2{font-family:var(--serif);font-size:clamp(2.5rem,5vw,5.5rem);font-weight:300;letter-spacing:-.02em;line-height:1.0;margin-bottom:18px}
.cta-h2 em{font-style:italic;color:var(--gold);display:block}
.cta-sub{font-size:.92rem;color:var(--gray);font-weight:300;line-height:1.8;max-width:420px;margin:0 auto 12px}

/* Email bien visible */
